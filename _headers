/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

/
  Cache-Control: no-cache, max-age=0

/index.html
  Cache-Control: no-cache, max-age=0

/login
  Cache-Control: no-cache, max-age=0

/login/index.html
  Cache-Control: no-cache, max-age=0

/profile
  Cache-Control: no-cache, max-age=0

/profile/index.html
  Cache-Control: no-cache, max-age=0

/admin
  Cache-Control: no-store, no-cache, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

/admin/
  Cache-Control: no-store, no-cache, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

/admin.html
  Cache-Control: no-store, no-cache, max-age=0, must-revalidate
  Pragma: no-cache
  Expires: 0

/og.png
  Cache-Control: public, max-age=3600

/og-forecast.png
  Cache-Control: public, max-age=3600

/og-paper.png
  Cache-Control: public, max-age=3600

# 종목 목록 JSON(kr/us/coin, 합 ~316KB)은 ?v= 버전스탬프가 붙는데도 max-age=0 must-revalidate 라
# 매 페이지 로드마다 조건부 재검증 왕복(304)이 3회 발생했다. 목록은 거의 안 바뀌고(가격은 /api/quote 라이브)
# 버전스탬프로 신선도가 보장되므로 1일 캐시로 왕복 제거(초기 로딩 단축). 데이터 변경 시 ?v= 가 바뀌어 즉시 신선.
/data/*
  Cache-Control: public, max-age=86400

/assets/app.css
  Cache-Control: public, max-age=31536000, immutable

/assets/app.css.*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/app.js
  Cache-Control: public, max-age=31536000, immutable

/assets/app-config.js
  Cache-Control: public, max-age=31536000, immutable

/assets/app-auth.js
  Cache-Control: no-cache, max-age=0

/assets/app-auth-wizard.js
  Cache-Control: no-cache, max-age=0

/assets/app-paper.js
  Cache-Control: no-cache, max-age=0

/assets/community-ui.js
  Cache-Control: public, max-age=31536000, immutable

/assets/status.css
  Cache-Control: public, max-age=31536000, immutable

/assets/status.js
  Cache-Control: public, max-age=31536000, immutable

/assets/keep-awake.mp4
  Cache-Control: public, max-age=86400

/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/patch-notes.md
  Cache-Control: public, max-age=60

/ad-builder.html
  Cache-Control: no-store, max-age=0

/manifest.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=3600

/sw.js
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: no-cache

/assets/icon-192.png
  Cache-Control: public, max-age=86400

/assets/icon-512.png
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/icon-192.png
  Cache-Control: public, max-age=86400

/icon-512.png
  Cache-Control: public, max-age=86400

/assets/maskable-192.png
  Cache-Control: public, max-age=86400

/assets/maskable-512.png
  Cache-Control: public, max-age=86400

/assets/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/assets/excelkospi-logo.png
  Cache-Control: public, max-age=86400

/favicon.ico
  Content-Type: image/x-icon
  Cache-Control: public, max-age=86400

/assets/favicon.svg
  Cache-Control: public, max-age=86400

/assets/favicon-32.png
  Cache-Control: public, max-age=86400

/robots.txt
  Content-Type: text/plain; charset=utf-8

/sitemap.xml
  Content-Type: application/xml; charset=utf-8

/seo-sitemap.xml
  Content-Type: application/xml; charset=utf-8

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
